{
  "name": "security-documents-generator",
  "version": "2.0.0",
  "description": "Generate synthetic Security data for Elasticsearch and Kibana development, demos, and performance testing.",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc",
    "start": "node src/index.ts",
    "lint": "eslint",
    "format": "prettier --write .",
    "checks": "./scripts/checks.sh",
    "fix": "yarn lint --fix && yarn prettier --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": "24.15.0",
    "yarn": "^1.22.22"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^9.2.0",
    "@faker-js/faker": "^10.1.0",
    "@inquirer/prompts": "^8.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.2",
    "dayjs": "^1.11.20",
    "form-data": "^4.0.3",
    "globals": "^17.0.0",
    "lodash-es": "^4.17.21",
    "p-map": "^7.0.2",
    "p-retry": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cli-progress": "3.11.6",
    "@types/lodash-es": "4.17.12",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,js,yml,yaml}": [
      "prettier --write"
    ]
  }
}
